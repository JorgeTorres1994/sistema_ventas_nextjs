generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIAL
  CANCELLED
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  isActive    Boolean?         @default(true)
  createdAt   DateTime?        @default(now())
  updatedAt   DateTime         @updatedAt
  
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique // e.g., "products:create"
  module      String           // e.g., "products"
  action      String           // e.g., "create"
  description String?
  createdAt   DateTime?        @default(now())
  updatedAt   DateTime         @updatedAt
  
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String
  name           String
  avatarUrl      String?
  isActive       Boolean?       @default(true)
  lastLogin      DateTime?
  failedAttempts Int?           @default(0)
  createdAt      DateTime?      @default(now())
  updatedAt      DateTime       @updatedAt
  roleId         String?

  role           Role?          @relation(fields: [roleId], references: [id])
  sales          Sale[]
  cashRegisters  CashRegister[]
  auditLogs      AuditLog[]
  quotations     Quotation[]
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  dni       String    @unique
  email     String?
  phone     String?
  address   String?
  isActive      Boolean?  @default(true)
  loyaltyPoints Int       @default(0)
  createdAt     DateTime? @default(now())
  updatedAt     DateTime  @updatedAt

  sales     Sale[]
  quotations Quotation[]
}

model Supplier {
  id        String     @id @default(uuid())
  name      String
  dniRuc    String     @unique
  email     String?
  phone     String?
  address   String?
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime   @updatedAt

  purchases Purchase[]
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model Product {
  id            String          @id @default(uuid())
  name          String
  description   String?
  price         Decimal         @db.Decimal(10, 2)
  purchasePrice Decimal?        @default(0) @db.Decimal(10, 2)
  stock         Int             @default(0)
  imageUrl      String?
  categoryId    String?
  isActive      Boolean?        @default(true)
  createdAt     DateTime?       @default(now())
  updatedAt     DateTime        @updatedAt

  category      Category?       @relation(fields: [categoryId], references: [id])
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  stockMovements StockMovement[]
  promotions    ProductPromotion[]
  quotationItems QuotationItem[]
}

model Promotion {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        String    // PERCENTAGE, FIXED_AMOUNT, BOGO
  value       Decimal   @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(true)
  minPurchase Decimal?  @db.Decimal(10, 2)
  createdAt   DateTime? @default(now())
  updatedAt   DateTime  @updatedAt

  products    ProductPromotion[]
}

model ProductPromotion {
  productId   String
  promotionId String
  product     Product   @relation(fields: [productId], references: [id])
  promotion   Promotion @relation(fields: [promotionId], references: [id])
  @@id([productId, promotionId])
}

model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  type        String    // PERCENTAGE, FIXED_AMOUNT
  value       Decimal   @db.Decimal(10, 2)
  minPurchase Decimal?  @default(0) @db.Decimal(10, 2)
  maxDiscount Decimal?  @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime
  usageLimit  Int?
  usageCount  Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime? @default(now())
  updatedAt   DateTime  @updatedAt

  sales       Sale[]
}

model CashRegister {
  id              String          @id @default(uuid())
  userId          String
  openingDate     DateTime?       @default(now())
  closingDate     DateTime?
  openingBalance  Decimal         @db.Decimal(10, 2)
  closingBalance  Decimal?        @db.Decimal(10, 2)
  expectedBalance Decimal?        @db.Decimal(10, 2)
  status          String?         @default("OPEN")
  notes           String?
  createdAt       DateTime?       @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  sales           Sale[]
  cashMovements   CashMovement[]
  expenses        Expense[]
  creditPayments  CreditPayment[]
}

model Sale {
  id             String         @id @default(uuid())
  series         String?
  correlative    Int?
  documentType   String?
  subtotal       Decimal?       @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal?       @default(0) @db.Decimal(10, 2)
  taxRate        Decimal?       @default(18) @db.Decimal(5, 2)
  total          Decimal        @db.Decimal(10, 2)
  amountPaid     Decimal?       @default(0) @db.Decimal(10, 2)
  status         PaymentStatus? @default(PAID)
  createdAt      DateTime?      @default(now())
  userId         String
  customerId     String?
  cashRegisterId String?
  couponId       String?
  discountAmount Decimal?       @default(0) @db.Decimal(10, 2)
  pointsEarned   Int?           @default(0)
  pointsRedeemed Int?           @default(0)
  
  // Facturación Electrónica
  invoiceStatus  String?         @default("PENDING") // PENDING, SENT, ERROR
  externalId     String?         @unique
  pdfUrl         String?
  xmlUrl         String?
  cdrUrl         String?
  qrCode         String?
  sunatResponse  String?

  user           User           @relation(fields: [userId], references: [id])
  customer       Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cashRegister   CashRegister?  @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  coupon         Coupon?        @relation(fields: [couponId], references: [id])
  items          SaleItem[]
  payments       Payment[]
  creditSale     CreditSale?
}

model SaleItem {
  id        String   @id @default(uuid())
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  saleId    String
  productId String

  sale      Sale     @relation(fields: [saleId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id        String    @id @default(uuid())
  saleId    String
  amount    Decimal   @db.Decimal(10, 2)
  method    String
  createdAt DateTime? @default(now())

  sale      Sale      @relation(fields: [saleId], references: [id])
}

model Purchase {
  id               String          @id @default(uuid())
  total            Decimal         @db.Decimal(10, 2)
  subtotal         Decimal?        @default(0) @db.Decimal(10, 2)
  taxAmount        Decimal?        @default(0) @db.Decimal(10, 2)
  shippingCost     Decimal?        @default(0) @db.Decimal(10, 2)
  status           PurchaseStatus? @default(COMPLETED)
  notes            String?
  expectedDelivery DateTime?
  createdAt        DateTime?       @default(now())
  updatedAt        DateTime        @updatedAt
  supplierId       String

  supplier   Supplier        @relation(fields: [supplierId], references: [id])
  items      PurchaseItem[]
  creditPurchase CreditPurchase?
}

model PurchaseItem {
  id         String   @id @default(uuid())
  quantity   Int
  costPrice  Decimal  @db.Decimal(10, 2)
  purchaseId String
  productId  String

  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model StockMovement {
  id          String    @id @default(uuid())
  productId   String
  type        String    // IN, OUT
  quantity    Int
  unitCost    Decimal?  @db.Decimal(10, 2)
  totalCost   Decimal?  @db.Decimal(10, 2)
  prevStock   Int?
  nextStock   Int?
  prevValue   Decimal?  @db.Decimal(10, 2)
  nextValue   Decimal?  @db.Decimal(10, 2)
  reason      String?
  referenceId String?
  createdAt   DateTime? @default(now())

  product     Product   @relation(fields: [productId], references: [id])
}

model CashMovement {
  id             String       @id @default(uuid())
  cashRegisterId String
  type           String
  amount         Decimal      @db.Decimal(10, 2)
  description    String?
  createdAt      DateTime?    @default(now())

  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?
  module      String?   // e.g., "SALES", "INVENTORY", "AUTH"
  action      String?   // e.g., "CREATE", "UPDATE", "DELETE", "LOGIN"
  description String?
  details     Json?     // Almacenar el payload o cambios
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime? @default(now())

  user        User?     @relation(fields: [userId], references: [id])
}

model Setting {
  id           String   @id @default(uuid())
  businessName String?  @default("Lumen Ledger")
  logoUrl      String?
  address      String?
  phone        String?
  email        String?
  taxRate      Decimal  @default(18) @db.Decimal(5, 2)
  currency     String   @default("USD")
  dateFormat   String   @default("MM/DD/YYYY")
  updatedAt    DateTime @updatedAt
}

model PaymentMethod {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentSeries {
  id           String    @id @default(uuid())
  documentType String    // e.g., "FACTURA", "BOLETA"
  prefix       String    // e.g., "F001"
  startNumber  Int       @default(1)
  currentNumber Int      @default(0)
  description  String?
  isActive     Boolean?  @default(true)
  createdAt    DateTime? @default(now())
  updatedAt    DateTime  @updatedAt
}

model ExpenseCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isActive    Boolean?  @default(true)
  createdAt   DateTime? @default(now())
  updatedAt   DateTime  @updatedAt

  expenses    Expense[]
}

model Expense {
  id                String          @id @default(uuid())
  description       String
  amount            Decimal         @db.Decimal(10, 2)
  date              DateTime        @default(now())
  categoryId        String
  cashRegisterId    String?
  paymentMethod     String?         @default("CASH")
  referenceNumber   String?
  notes             String?
  createdAt         DateTime?       @default(now())
  updatedAt         DateTime        @updatedAt

  category          ExpenseCategory @relation(fields: [categoryId], references: [id])
  cashRegister      CashRegister?   @relation(fields: [cashRegisterId], references: [id])
}

model CreditSale {
  id             String         @id @default(uuid())
  saleId         String         @unique
  totalAmount    Decimal        @db.Decimal(10, 2)
  remainingAmount Decimal        @db.Decimal(10, 2)
  dueDate        DateTime?
  status         String         @default("PENDING") // PENDING, PAID, OVERDUE
  createdAt      DateTime?      @default(now())
  updatedAt      DateTime       @updatedAt

  sale           Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  payments       CreditPayment[]
}

model CreditPurchase {
  id             String         @id @default(uuid())
  purchaseId     String         @unique
  totalAmount    Decimal        @db.Decimal(10, 2)
  remainingAmount Decimal        @db.Decimal(10, 2)
  dueDate        DateTime?
  status         String         @default("PENDING") // PENDING, PAID, OVERDUE
  createdAt      DateTime?      @default(now())
  updatedAt      DateTime       @updatedAt

  purchase       Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  payments       CreditPayment[]
}

model CreditPayment {
  id               String          @id @default(uuid())
  amount           Decimal         @db.Decimal(10, 2)
  date             DateTime        @default(now())
  paymentMethod    String          @default("CASH")
  notes            String?
  creditSaleId     String?
  creditPurchaseId String?
  cashRegisterId   String?

  creditSale       CreditSale?     @relation(fields: [creditSaleId], references: [id])
  creditPurchase   CreditPurchase? @relation(fields: [creditPurchaseId], references: [id])
  cashRegister     CashRegister?   @relation(fields: [cashRegisterId], references: [id])
}

model Quotation {
  id             String          @id @default(uuid())
  number         String          @unique
  subtotal       Decimal         @db.Decimal(10, 2)
  taxAmount      Decimal         @db.Decimal(10, 2)
  total          Decimal         @db.Decimal(10, 2)
  status         String          @default("PENDING") // PENDING, ACCEPTED, REJECTED, EXPIRED, CONVERTED
  expirationDate DateTime
  notes          String?
  createdAt      DateTime?       @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String
  customerId     String?

  user           User            @relation(fields: [userId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items          QuotationItem[]
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  productId   String
  quantity    Int
  price       Decimal   @db.Decimal(10, 2)

  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
}
